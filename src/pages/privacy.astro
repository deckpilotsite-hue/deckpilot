---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Privacy Policy – DeckPilot" description="DeckPilot privacy policy.">
  <div class="max-w-4xl mx-auto px-4 py-10">
    <h1 class="text-3xl font-black text-slate-900 dark:text-white mb-8">Privacy Policy</h1>
    <div class="prose dark:prose-invert max-w-none text-slate-600 dark:text-slate-400">
      <p>This site may collect basic usage data. We do not sell your personal information. See our cookie and analytics policies for details.</p>
    </div>
  </div>
</BaseLayout>
