---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';
const entry = await getEntry('pages', 'about');
if (!entry) {
  return Astro.redirect('/404');
}
const { Content } = await render(entry);
const title = entry.data.seo?.title ?? entry.data.title;
const description = entry.data.seo?.description ?? undefined;
---

<BaseLayout title={title} description={description}>
  <div class="max-w-4xl mx-auto px-4 py-10">
    <h1 class="text-3xl font-black text-slate-900 dark:text-white mb-8">{entry.data.title}</h1>
    <div class="prose dark:prose-invert max-w-none">
      <Content />
    </div>
  </div>
</BaseLayout>
