---
import BaseLayout from '../layouts/BaseLayout.astro';
import RatingStars from '../components/RatingStars.astro';
import AffiliateDisclosureInline from '../components/AffiliateDisclosureInline.astro';
import { getCollection } from 'astro:content';
import { tools, getToolByKey } from '../data/tools';

const topTools = tools.slice(0, 4);
const reviews = (await getCollection('reviews')).sort(
  (a, b) => b.data.updatedAt.valueOf() - a.data.updatedAt.valueOf()
);
const latestReviews = reviews.slice(0, 3);
---

<BaseLayout title="DeckPilot – AI Presentation Tool Reviews" description="Find and compare the best AI presentation and pitch deck tools. Honest reviews, alternatives, and guides.">
  <!-- Hero Section -->
  <section class="py-12 lg:py-20">
    <div class="grid lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-6 space-y-8">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 text-primary text-xs font-bold uppercase tracking-wider">
          <span class="material-symbols-outlined text-sm">verified</span>
          Expert Software Analysis
        </div>
        <h1 class="text-5xl lg:text-7xl font-black leading-[1.1] tracking-tight text-slate-900 dark:text-white">
          Navigate the Best Software with <span class="text-primary">Confidence</span>
        </h1>
        <p class="text-lg lg:text-xl text-slate-600 dark:text-slate-400 leading-relaxed max-w-xl">
          In-depth reviews and expert guides to help you choose the right tools for your business. We test thousands of products so you don't have to.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/reviews/" class="bg-primary text-white px-8 py-4 rounded-xl text-lg font-bold hover:scale-[1.02] active:scale-95 transition-all shadow-xl shadow-primary/20 inline-flex items-center justify-center">
            Explore Reviews
          </a>
          <a href="/best-ai-presentation-tools/" class="bg-white dark:bg-slate-900 border-2 border-slate-200 dark:border-slate-700 text-slate-900 dark:text-white px-8 py-4 rounded-xl text-lg font-bold hover:bg-slate-50 dark:hover:bg-slate-800 transition-all inline-flex items-center justify-center">
            How we rank
          </a>
        </div>
      </div>
      <div class="lg:col-span-6 relative hidden lg:block">
        <div class="aspect-square rounded-3xl overflow-hidden shadow-2xl relative z-10 bg-slate-200 dark:bg-slate-800">
          <div class="w-full h-full flex items-center justify-center text-slate-400 dark:text-slate-500">
            <span class="material-symbols-outlined text-8xl">dashboard</span>
          </div>
        </div>
        <div class="absolute -bottom-6 -left-6 bg-white dark:bg-slate-900 p-6 rounded-2xl shadow-xl z-20 border border-slate-100 dark:border-slate-800 hidden xl:block">
          <div class="flex items-center gap-4">
            <div class="size-12 rounded-full bg-green-100 dark:bg-green-900/30 flex items-center justify-center text-green-600 dark:text-green-400">
              <span class="material-symbols-outlined">trending_up</span>
            </div>
            <div>
              <p class="text-xs font-bold text-slate-400 uppercase tracking-widest">Efficiency Gain</p>
              <p class="text-2xl font-black text-slate-900 dark:text-white">+42% Avg.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Top Picks 2024 -->
  <section class="py-16 border-t border-slate-100 dark:border-slate-800">
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-10">
      <div>
        <h2 class="text-3xl font-black text-slate-900 dark:text-white tracking-tight">Top Picks 2024</h2>
        <p class="text-slate-500 dark:text-slate-400 mt-1">Hand-selected best-in-class solutions for your workflow</p>
      </div>
      <a href="/best-ai-presentation-tools/" class="text-primary font-bold flex items-center gap-1 group w-fit">
        View all categories
        <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">arrow_forward</span>
      </a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {topTools.map((tool) => (
        <a href={`/reviews/${tool.key}/`} class="group block">
          <div class="aspect-[16/10] rounded-2xl overflow-hidden mb-4 bg-slate-100 dark:bg-slate-800 relative">
            {tool.screenshot ? (
              <img src={tool.screenshot} alt={tool.name} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
            ) : (
              <div class="w-full h-full flex items-center justify-center text-slate-400 dark:text-slate-500">
                <span class="material-symbols-outlined text-5xl">slideshow</span>
              </div>
            )}
          </div>
          <h3 class="font-bold text-lg text-slate-900 dark:text-white group-hover:text-primary transition-colors">{tool.name}</h3>
          <p class="text-slate-500 dark:text-slate-400 text-sm">{tool.shortDesc}</p>
          <div class="mt-2 flex items-center gap-2 text-[10px] font-bold text-slate-400 uppercase">
            <span class="material-symbols-outlined text-xs">calendar_today</span>
            Updated 2024
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Latest Reviews -->
  <section class="py-16 border-t border-slate-100 dark:border-slate-800">
    <h2 class="text-3xl font-black text-slate-900 dark:text-white tracking-tight mb-10">Latest Reviews</h2>
    <div class="grid lg:grid-cols-3 gap-8">
      {latestReviews.map((entry) => {
        const tool = getToolByKey(entry.data.slug);
        const rating = entry.data.rating ?? tool?.rating ?? 0;
        return (
          <article class="bg-white dark:bg-slate-900 border border-slate-100 dark:border-slate-800 rounded-2xl p-6 hover:shadow-xl hover:border-transparent transition-all group">
            <div class="flex items-center gap-4 mb-6">
              <div class="size-14 rounded-xl bg-slate-50 dark:bg-slate-800 flex items-center justify-center p-2 overflow-hidden">
                {tool?.logo ? (
                  <img src={tool.logo} alt="" class="w-full h-full object-contain opacity-80" />
                ) : (
                  <span class="material-symbols-outlined text-3xl text-slate-400">apps</span>
                )}
              </div>
              <div>
                <h4 class="font-bold text-xl text-slate-900 dark:text-white">{entry.data.title}</h4>
                <div class="flex items-center gap-1 mt-0.5">
                  <RatingStars rating={rating} />
                  <span class="text-slate-400 dark:text-slate-500 text-xs ml-2 font-bold">({rating}/5)</span>
                </div>
              </div>
            </div>
            <p class="text-slate-600 dark:text-slate-300 line-clamp-3 mb-6">{entry.data.tagline}</p>
            <div class="flex items-center justify-between pt-6 border-t border-slate-50 dark:border-slate-800">
              <span class="text-xs font-semibold text-slate-500 dark:text-slate-400">Expert review</span>
              <a href={`/reviews/${entry.data.slug}/`} class="text-primary font-bold text-sm group-hover:underline">
                Read Review
              </a>
            </div>
          </article>
        );
      })}
    </div>
    {latestReviews.length === 0 && (
      <p class="text-slate-600 dark:text-slate-400">No reviews yet.</p>
    )}
  </section>

  <section class="pt-8 border-t border-slate-200 dark:border-slate-800">
    <AffiliateDisclosureInline />
  </section>
</BaseLayout>
