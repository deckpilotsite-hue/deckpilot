---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Affiliate Disclosure – DeckPilot" description="DeckPilot affiliate disclosure and how we earn from recommendations.">
  <div class="max-w-4xl mx-auto px-4 py-10">
    <h1 class="text-3xl font-black text-slate-900 dark:text-white mb-8">Affiliate Disclosure</h1>
    <div class="prose dark:prose-invert max-w-none text-slate-600 dark:text-slate-400">
      <p>We may earn a commission when you sign up or make a purchase through links on our site. This does not affect our editorial reviews or rankings. We only recommend tools we believe add value.</p>
    </div>
  </div>
</BaseLayout>
