---
import type { Tool } from '../data/tools';
import { resolveCtaHref } from '../data/affiliates';
import RatingStars from './RatingStars.astro';

type Props = {
  tool: Tool;
  /** Optional CTA label; if not set, no CTA is shown. */
  ctaLabel?: string;
  /** Optional affiliate key for CTA; resolved via affiliates.ts. */
  affiliateKey?: string;
};

const { tool, ctaLabel, affiliateKey } = Astro.props;
const showCta = ctaLabel && (affiliateKey ?? tool.key);
const ctaHref = showCta ? resolveCtaHref(affiliateKey ?? tool.key, tool.website) : '';
---

<article class="rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900/50 p-5 shadow-sm hover:shadow-md transition-shadow">
  <div class="flex flex-col gap-3">
    <h3 class="font-bold text-lg text-slate-900 dark:text-white">{tool.name}</h3>
    <p class="text-sm text-slate-600 dark:text-slate-400 line-clamp-2">{tool.shortDesc}</p>
    {tool.rating != null && (
      <RatingStars rating={tool.rating} />
    )}
    <p class="text-sm font-medium text-slate-700 dark:text-slate-300">{tool.pricingText}</p>
    {showCta && (
      <a
        href={ctaHref}
        target="_blank"
        rel="noopener noreferrer sponsored"
        class="inline-flex items-center justify-center gap-1 bg-[#4848e5] hover:bg-[#4848e5]/90 text-white font-semibold py-2 px-4 rounded-lg text-sm transition-colors"
      >
        {ctaLabel}
      </a>
    )}
  </div>
</article>
