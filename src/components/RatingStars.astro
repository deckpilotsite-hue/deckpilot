---
type Props = { rating: number };
const { rating } = Astro.props;
const full = Math.floor(rating);
const half = rating % 1 >= 0.5 ? 1 : 0;
const empty = 5 - full - half;
---

<div class="flex items-center gap-1 text-amber-500" role="img" aria-label={`Rating: ${rating} out of 5`}>
  {Array.from({ length: full }, () => (
    <span class="material-symbols-outlined text-lg" style="font-variation-settings: 'FILL' 1">star</span>
  ))}
  {half > 0 && <span class="material-symbols-outlined text-lg" style="font-variation-settings: 'FILL' 1">star_half</span>}
  {Array.from({ length: empty }, () => (
    <span class="material-symbols-outlined text-lg text-slate-300 dark:text-slate-600">star</span>
  ))}
</div>
