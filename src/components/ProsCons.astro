---
type Props = { pros: string[]; cons: string[] };
const { pros, cons } = Astro.props;
---

<div class="grid md:grid-cols-2 bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 overflow-hidden shadow-sm">
  <div class="p-8 border-b md:border-b-0 md:border-r border-slate-200 dark:border-slate-700">
    <div class="flex items-center gap-2 text-green-600 dark:text-green-400 font-bold mb-6">
      <span class="material-symbols-outlined">add_circle</span>
      What We Liked
    </div>
    <ul class="space-y-4">
      {pros.map((p) => (
        <li class="flex gap-3 text-slate-700 dark:text-slate-300">
          <span class="material-symbols-outlined text-green-500 text-sm mt-1 shrink-0">check_circle</span>
          {p}
        </li>
      ))}
    </ul>
  </div>
  <div class="p-8 bg-slate-50/50 dark:bg-slate-900/50">
    <div class="flex items-center gap-2 text-red-500 font-bold mb-6">
      <span class="material-symbols-outlined">remove_circle</span>
      Room for Improvement
    </div>
    <ul class="space-y-4">
      {cons.map((c) => (
        <li class="flex gap-3 text-slate-700 dark:text-slate-300">
          <span class="material-symbols-outlined text-red-400 text-sm mt-1 shrink-0">cancel</span>
          {c}
        </li>
      ))}
    </ul>
  </div>
</div>
