---
type Props = {
  /** Optional number of columns; default responsive grid. */
  columns?: 2 | 3 | 4;
};

const { columns = 3 } = Astro.props;
const gridClass = columns === 2 ? 'grid-cols-1 sm:grid-cols-2' : columns === 4 ? 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-4' : 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-3';
---

<div class={`grid gap-6 ${gridClass}`}>
  <slot />
</div>
