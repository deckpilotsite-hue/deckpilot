---
const navLinks = [
  { label: 'Tools', href: '/tools/' },
  { label: 'Reviews', href: '/reviews/' },
  { label: 'Best', href: '/best/' },
  { label: 'Guides', href: '/guides/' },
];
---

<header class="sticky top-0 z-50 w-full bg-white/95 dark:bg-background-dark/80 backdrop-blur-sm border-b border-slate-200 dark:border-slate-800">
  <div class="max-w-[1200px] mx-auto px-6 h-16 flex items-center justify-between">
    <div class="flex items-center gap-10">
      <a href="/" class="flex items-center gap-2 group" aria-label="DeckPilot home">
        <span class="size-8 bg-primary rounded-lg flex items-center justify-center text-white" aria-hidden="true">
          <span class="material-symbols-outlined text-xl">rocket_launch</span>
        </span>
        <span class="text-xl font-black tracking-tight text-slate-900 dark:text-white">DeckPilot</span>
      </a>
      <nav class="hidden md:flex items-center gap-8" aria-label="Main navigation">
        {navLinks.map((link) => (
          <a href={link.href} class="text-sm font-semibold text-slate-600 dark:text-slate-400 hover:text-primary dark:hover:text-primary transition-colors">
            {link.label}
          </a>
        ))}
      </nav>
    </div>
    <div class="flex items-center gap-6">
      <div class="relative hidden lg:block">
        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-lg" aria-hidden="true">search</span>
        <input
          type="search"
          class="pl-10 pr-4 py-2 bg-slate-100 dark:bg-slate-800 border-none rounded-full text-sm w-64 focus:ring-2 focus:ring-primary/20 focus:bg-white dark:focus:bg-slate-700 transition-all"
          placeholder="Search software..."
          aria-label="Search software"
        />
      </div>
      <a href="/best-ai-presentation-tools/" class="bg-primary text-white px-5 py-2 rounded-full text-sm font-bold hover:shadow-lg hover:shadow-primary/20 transition-all hidden md:inline-flex">
        Best Tools
      </a>
      <button type="button" class="md:hidden p-2 text-slate-600 dark:text-slate-400 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-nav" id="header-menu-btn">
        <span class="material-symbols-outlined text-3xl">menu</span>
      </button>
      <div class="size-10 rounded-full bg-slate-200 dark:bg-slate-700 overflow-hidden border border-slate-200 dark:border-slate-600 hidden sm:block" aria-hidden="true">
        <span class="w-full h-full flex items-center justify-center text-slate-500 dark:text-slate-400 text-sm font-bold">?</span>
      </div>
    </div>
  </div>
  <!-- Mobile nav drawer -->
  <div id="mobile-nav" class="hidden md:hidden border-t border-slate-200 dark:border-slate-800 bg-white dark:bg-background-dark" aria-hidden="true">
    <nav class="max-w-[1200px] mx-auto px-6 py-4 flex flex-col gap-2" aria-label="Mobile navigation">
      {navLinks.map((link) => (
        <a href={link.href} class="text-sm font-semibold text-slate-600 dark:text-slate-400 hover:text-primary py-2">
          {link.label}
        </a>
      ))}
      <a href="/best-ai-presentation-tools/" class="bg-primary text-white px-5 py-2.5 rounded-full text-sm font-bold mt-2 inline-flex w-fit">
        Best Tools
      </a>
    </nav>
  </div>
</header>
<script>
  const btn = document.getElementById('header-menu-btn');
  const drawer = document.getElementById('mobile-nav');
  if (btn && drawer) {
    btn.addEventListener('click', () => {
      const open = drawer.classList.toggle('hidden');
      btn.setAttribute('aria-expanded', String(!open));
      btn.setAttribute('aria-label', open ? 'Open menu' : 'Close menu');
    });
  }
</script>
